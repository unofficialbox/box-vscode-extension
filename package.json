{
  "name": "box-vscode-extension",
  "displayName": "Box",
  "description": "Box developer tools to accelerate the creation of Box developer applications and solutions.",
  "version": "0.0.1",
  "publisher":"box",
  "homepage": "https://github.com/unofficialbox/box-vscode-extension",
  "icon":"resources/extensionIcon.png",
  "galleryBanner": {
        "color": "#4E4E4E",
        "theme": "dark"
    },
  "engines": {
    "vscode": "^1.105.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unofficialbox/box-vscode-extension.git"
  },
  "bugs": {
      "url": "https://github.com/unofficialbox/box-vscode-extension/issues"
  },
  "qna": "https://github.com/unofficialbox/box-vscode-extension/discussions/categories/q-a",
  "categories": [
    "Testing",
    "Visualization",
    "Other",
    "Snippets"
  ],
  "keywords": [
    "box",
    "vscode",
    "content",
    "ecm",
    "ai",
    "agents",
    "cloud"
  ],
  "activationEvents": [
    "workspaceContains:box-project.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "box-vscode-extension.createProject",
        "title": "Box: Create Box Project"
      },
      {
        "command": "box-vscode-extension.resetWorkspaceContext",
        "title": "Box: Reset Workspace Context"
      },
      {
        "command": "box-vscode-extension.authorize",
        "title": "Box: Authorize Connection (OAuth 2.0)"
      },
      {
        "command": "box-vscode-extension.displayAllConnections",
        "title": "Box: Display All Box Connections"
      },
      {
        "command": "box-vscode-extension.displayDefaultConnection",
        "title": "Box: Display the Default Box Connection"
      },
      {
        "command": "box-vscode-extension.setDefaultConnection",
        "title": "Box: Set the Default Box Connection"
      },
      {
        "command": "box-vscode-extension.removeConnection",
        "title": "Box: Remove Box Connection"
      },
      {
        "command": "box-vscode-extension.getAccessToken",
        "title": "Box: Get Access Token"
      },
      {
        "command": "box-vscode-extension.refreshAllFiles",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "box-vscode-extension.previewFile",
        "title": "Box: Preview File"
      },
      {
        "command": "box-vscode-extension.refreshConfiguration",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "box-vscode-extension.showMetadataTemplate",
        "title": "Box: Show Metadata Template",
        "icon": "$(edit)"
      },
      {
        "command": "box-vscode-extension.copyToClipboard",
        "title": "Copy to Clipboard",
        "icon": "$(clippy)"
      },
      {
        "command": "box-vscode-extension.saveMetadataTemplateJson",
        "title": "Save Template JSON",
        "icon": "$(desktop-download)"
      },
      {
        "command": "box-vscode-extension.showMetadataTaxonomy",
        "title": "Box: Show Metadata Taxonomy",
        "icon": "$(edit)"
      },
      {
        "command": "box-vscode-extension.saveMetadataTaxonomyJson",
        "title": "Save Taxonomy JSON",
        "icon": "$(desktop-download)"
      },
      {
        "command": "box-vscode-extension.showTaxonomyNode",
        "title": "Box: Show Taxonomy Node",
        "icon": "$(edit)"
      },
      {
        "command": "box-vscode-extension.createMetadataTemplate",
        "title": "Create Metadata Template",
        "icon": "$(add)"
      },
      {
        "command": "box-vscode-extension.createMetadataTaxonomy",
        "title": "Create Metadata Taxonomy",
        "icon": "$(add)"
      },
      {
        "command": "box-vscode-extension.showEnterpriseConfiguration",
        "title": "Show Enterprise Configuration",
        "icon": "$(settings-gear)"
      },
      {
        "command": "box-vscode-extension.openUIElement",
        "title": "Box: Open UI Element"
      },
      {
        "command": "box-vscode-extension.openMetadataQueryBuilder",
        "title": "Box: Metadata Query Builder",
        "icon": "$(search)"
      },
      {
        "command": "box-vscode-extension.deployToDefaultEnterprise",
        "title": "Box: Deploy to Default Box Enterprise",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "box-vscode-extension.deployToTargetEnterprise",
        "title": "Box: Deploy to Target Box Enterprise",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "box-vscode-extension.copyFolderId",
        "title": "Copy Folder ID",
        "icon": "$(clippy)"
      },
      {
        "command": "box-vscode-extension.copyFileId",
        "title": "Copy File ID",
        "icon": "$(clippy)"
      },
      {
        "command": "box-vscode-extension.showContentUploader",
        "title": "Show Content Uploader",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "box-vscode-extension.showContentPicker",
        "title": "Show Content Picker",
        "icon": "$(file-symlink-directory)"
      },
      {
        "command": "box-vscode-extension.showContentExplorer",
        "title": "Show Content Explorer",
        "icon": "$(root-folder)"
      },
      {
        "command": "box-vscode-extension.createFolder",
        "title": "Create Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "box-vscode-extension.refreshFolder",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "box-vscode-extension.deleteItem",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "box-vscode-extension.createFolderAtRoot",
        "title": "Create Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "box-vscode-extension.filterAllFiles",
        "title": "Filter",
        "icon": "$(filter)"
      },
      {
        "command": "box-vscode-extension.clearFilterAllFiles",
        "title": "Clear Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "box-vscode-extension.downloadItem",
        "title": "Download",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "box-vscode-extension.filterAllFiles",
          "when": "view == box-vscode-extension.allFilesView && !box.allFilesFiltered",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.clearFilterAllFiles",
          "when": "view == box-vscode-extension.allFilesView && box.allFilesFiltered",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.createFolderAtRoot",
          "when": "view == box-vscode-extension.allFilesView",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.refreshAllFiles",
          "when": "view == box-vscode-extension.allFilesView",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.refreshConfiguration",
          "when": "view == box-vscode-extension.configurationView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "box-vscode-extension.refreshFolder",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "inline@1"
        },
        {
          "command": "box-vscode-extension.createFolder",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "inline@2"
        },
        {
          "command": "box-vscode-extension.copyFolderId",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "inline@3"
        },
        {
          "command": "box-vscode-extension.downloadItem",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "inline@4"
        },
        {
          "command": "box-vscode-extension.deleteItem",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "inline@5"
        },
        {
          "command": "box-vscode-extension.copyFileId",
          "when": "view == box-vscode-extension.allFilesView && viewItem == file",
          "group": "inline@1"
        },
        {
          "command": "box-vscode-extension.downloadItem",
          "when": "view == box-vscode-extension.allFilesView && viewItem == file",
          "group": "inline@2"
        },
        {
          "command": "box-vscode-extension.deleteItem",
          "when": "view == box-vscode-extension.allFilesView && viewItem == file",
          "group": "inline@3"
        },
        {
          "command": "box-vscode-extension.previewFile",
          "when": "view == box-vscode-extension.allFilesView && viewItem == file",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.copyFileId",
          "when": "view == box-vscode-extension.allFilesView && viewItem == file",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.copyFolderId",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.refreshFolder",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.createFolder",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.downloadItem",
          "when": "view == box-vscode-extension.allFilesView && viewItem =~ /^(folder|file)$/",
          "group": "navigation"
        },
        {
          "command": "box-vscode-extension.deleteItem",
          "when": "view == box-vscode-extension.allFilesView && viewItem =~ /^(folder|file)$/",
          "group": "danger"
        },
        {
          "command": "box-vscode-extension.showContentUploader",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "uielements"
        },
        {
          "command": "box-vscode-extension.showContentPicker",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "uielements"
        },
        {
          "command": "box-vscode-extension.showContentExplorer",
          "when": "view == box-vscode-extension.allFilesView && viewItem == folder",
          "group": "uielements"
        },
        {
          "command": "box-vscode-extension.copyToClipboard",
          "when": "view == box-vscode-extension.configurationView && viewItem == metadataTemplate",
          "group": "inline"
        },
        {
          "command": "box-vscode-extension.saveMetadataTemplateJson",
          "when": "view == box-vscode-extension.configurationView && viewItem == metadataTemplate",
          "group": "inline"
        },
        {
          "command": "box-vscode-extension.showMetadataTemplate",
          "when": "view == box-vscode-extension.configurationView && viewItem == metadataTemplate",
          "group": "inline"
        },
        {
          "command": "box-vscode-extension.copyToClipboard",
          "when": "view == box-vscode-extension.configurationView && viewItem == metadataTaxonomy",
          "group": "inline"
        },
        {
          "command": "box-vscode-extension.saveMetadataTaxonomyJson",
          "when": "view == box-vscode-extension.configurationView && viewItem == metadataTaxonomy",
          "group": "inline"
        },
        {
          "command": "box-vscode-extension.showMetadataTaxonomy",
          "when": "view == box-vscode-extension.configurationView && viewItem == metadataTaxonomy",
          "group": "inline"
        },
        {
          "command": "box-vscode-extension.createMetadataTemplate",
          "when": "view == box-vscode-extension.configurationView && viewItem == subcategoryTemplates",
          "group": "inline"
        },
        {
          "command": "box-vscode-extension.createMetadataTaxonomy",
          "when": "view == box-vscode-extension.configurationView && viewItem == categoryTaxonomies",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "command": "box-vscode-extension.deployToDefaultEnterprise",
          "when": "explorerResourceIsFolder && resourceFilename =~ /^(metadata-templates|metadata-taxonomies|folders)$/",
          "group": "box@1"
        },
        {
          "command": "box-vscode-extension.deployToTargetEnterprise",
          "when": "explorerResourceIsFolder && resourceFilename =~ /^(metadata-templates|metadata-taxonomies|folders)$/",
          "group": "box@2"
        },
        {
          "command": "box-vscode-extension.deployToDefaultEnterprise",
          "when": "resourceFilename =~ /\\.json$/ && resourcePath =~ /metadata-templates|metadata-taxonomies/",
          "group": "box@1"
        },
        {
          "command": "box-vscode-extension.deployToTargetEnterprise",
          "when": "resourceFilename =~ /\\.json$/ && resourcePath =~ /metadata-templates|metadata-taxonomies/",
          "group": "box@2"
        },
        {
          "command": "box-vscode-extension.deployToDefaultEnterprise",
          "when": "explorerResourceIsFolder && resourcePath =~ /[/\\\\]folders[/\\\\]/",
          "group": "box@1"
        },
        {
          "command": "box-vscode-extension.deployToTargetEnterprise",
          "when": "explorerResourceIsFolder && resourcePath =~ /[/\\\\]folders[/\\\\]/",
          "group": "box@2"
        },
        {
          "command": "box-vscode-extension.deployToDefaultEnterprise",
          "when": "!explorerResourceIsFolder && resourcePath =~ /[/\\\\]folders[/\\\\]/",
          "group": "box@1"
        },
        {
          "command": "box-vscode-extension.deployToTargetEnterprise",
          "when": "!explorerResourceIsFolder && resourcePath =~ /[/\\\\]folders[/\\\\]/",
          "group": "box@2"
        }
      ],
      "commandPalette": [
        {
          "command": "box-vscode-extension.createProject",
          "when": "!project.generated"
        },
        {
          "command": "box-vscode-extension.resetWorkspaceContext",
          "when": "debug.running == true"
        },
        {
          "command": "box-vscode-extension.authorize",
          "when": "project.generated"
        },
        {
          "command": "box-vscode-extension.displayAllConnections",
          "when": "project.generated && box.authenticated"
        },
        {
          "command": "box-vscode-extension.displayDefaultConnection",
          "when": "project.generated && box.authenticated"
        },
        {
          "command": "box-vscode-extension.setDefaultConnection",
          "when": "project.generated && box.authenticated"
        },
        {
          "command": "box-vscode-extension.removeConnection",
          "when": "project.generated && box.authenticated"
        },
        {
          "command": "box-vscode-extension.getAccessToken",
          "when": "project.generated && box.authenticated"
        },
        {
          "command": "box-vscode-extension.previewFile",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.refreshConfiguration",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.showMetadataTemplate",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.copyToClipboard",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.saveMetadataTemplateJson",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.showMetadataTaxonomy",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.saveMetadataTaxonomyJson",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.showTaxonomyNode",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.createMetadataTemplate",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.createMetadataTaxonomy",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.openUIElement",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.openMetadataQueryBuilder",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.deployToDefaultEnterprise",
          "when": "project.generated && box.authenticated"
        },
        {
          "command": "box-vscode-extension.deployToTargetEnterprise",
          "when": "project.generated && box.authenticated"
        },
        {
          "command": "box-vscode-extension.copyFolderId",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.copyFileId",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.showContentUploader",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.showContentPicker",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.showContentExplorer",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.createFolder",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.refreshFolder",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.deleteItem",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.createFolderAtRoot",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.filterAllFiles",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.clearFilterAllFiles",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.showEnterpriseConfiguration",
          "when": "false"
        },
        {
          "command": "box-vscode-extension.downloadItem",
          "when": "false"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "box-explorer",
          "title": "Box",
          "icon": "resources/activityBarIcon.png"
        }
      ]
    },
    "views": {
      "box-explorer": [
        {
          "id": "box-vscode-extension.allFilesView",
          "name": "All Files"
        },
        {
          "id": "box-vscode-extension.configurationView",
          "name": "Configuration"
        },
        {
          "id": "box-vscode-extension.uiElementsView",
          "name": "UI Elements"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "box-vscode-extension.allFilesView",
        "contents": "No Box files to show.\n[Authorize Connection](command:box-vscode-extension.authorize)",
        "when": "!box.authenticated"
      },
      {
        "view": "box-vscode-extension.configurationView",
        "contents": "No configuration available.\n[Create Box Project](command:box-vscode-extension.createProject)",
        "when": "!project.generated"
      },
      {
        "view": "box-vscode-extension.uiElementsView",
        "contents": "No UI elements to display."
      }
    ],
    "configuration": []
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "box-annotations": "^5.2.1-beta.0",
    "box-ui-elements": "^26.0.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "box-node-sdk": "^10.4.0"
  }
}
